[
  {
    "name": "chrome-centered-2560",
    "url": "/DSA/lectures/ch_4/",
    "viewport": { "w": 2560, "h": 1080 },
    "asserts": [
      {
        "type": "rect",
        "selector": ".chrome",
        "prop": "width",
        "op": "<=",
        "expected": 1400
      },
      {
        "type": "rect",
        "selector": ".chrome",
        "prop": "left",
        "op": ">=",
        "expected": 100
      }
    ]
  },
  {
    "name": "chrome-fills-1024",
    "url": "/DSA/lectures/ch_4/",
    "viewport": { "w": 1024, "h": 768 },
    "asserts": [
      {
        "type": "rect",
        "selector": ".chrome",
        "prop": "width",
        "op": "between",
        "expected": [1000, 1024]
      },
      {
        "type": "rect",
        "selector": ".chrome",
        "prop": "left",
        "op": "==",
        "expected": 0
      }
    ]
  },
  {
    "name": "left-rail-sticky-after-scroll-ch4",
    "url": "/DSA/lectures/ch_4/",
    "viewport": { "w": 1280, "h": 800 },
    "scroll": 2000,
    "asserts": [
      {
        "type": "rect",
        "selector": "aside[data-slot=\"left-rail\"]",
        "prop": "top",
        "op": "between",
        "expected": [0, 100]
      }
    ]
  },
  {
    "name": "right-rail-sticky-after-scroll-ch4",
    "url": "/DSA/lectures/ch_4/",
    "viewport": { "w": 1280, "h": 800 },
    "scroll": 2000,
    "asserts": [
      {
        "type": "rect",
        "selector": "aside[data-slot=\"right-rail\"]",
        "prop": "top",
        "op": "between",
        "expected": [0, 100]
      }
    ]
  },
  {
