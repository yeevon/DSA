  {
    "name": "breadcrumb-current-page-no-link",
    "url": "/DSA/lectures/ch_4/",
    "viewport": { "w": 1280, "h": 800 },
    "asserts": [
      {
        "type": "aria-current",
        "selector": ".breadcrumb-path .path-current",
        "expected": "page"
      },
      {
        "type": "count",
        "selector": ".breadcrumb-path a[aria-current=\"page\"]",
        "expected": 0
      },
      {
        "type": "count",
        "selector": ".breadcrumb-path span.path-current[aria-current=\"page\"]",
        "expected": 1
      }
    ]
  },
