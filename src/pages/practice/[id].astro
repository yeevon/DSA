---
// src/pages/practice/[id].astro
//
// M2 Task T5b — dynamic route for chapter practice prompts.
// Practice MDX is plain markdown (no callouts in the source);
// the components map is included for symmetry but most practice
// content won't reach for the callout JSX tags.
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Definition from '../../components/callouts/Definition.astro';
import KeyIdea from '../../components/callouts/KeyIdea.astro';
import Gotcha from '../../components/callouts/Gotcha.astro';
import Example from '../../components/callouts/Example.astro';
import Aside from '../../components/callouts/Aside.astro';
import CodeBlock from '../../components/callouts/CodeBlock.astro';
import LeftRail from '../../components/chrome/LeftRail.astro';
import Breadcrumb from '../../components/chrome/Breadcrumb.astro';

export async function getStaticPaths() {
  const practice = await getCollection('practice');
  return practice.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={`${entry.data.title} — Practice`}>
  <Breadcrumb slot="breadcrumb" />
  <LeftRail slot="left-rail" />
  <header>
    <h1>{entry.data.title} — Practice</h1>
    <p><em>{entry.data.subtitle}</em></p>
  </header>
  <article>
    <Content components={{ Definition, KeyIdea, Gotcha, Example, Aside, CodeBlock }} />
  </article>
</Base>
