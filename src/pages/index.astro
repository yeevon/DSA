---
// src/pages/index.astro — M-UX T5 deliverable.
//
// Replaces the M2 T5a/T5b two-table chapter-listing layout with the
// mastery-dashboard placeholder per ADR-0002 + T5 spec:
//   - Two `data-interactive-only` dashboard slots at the top
//     ("Recently read" + "Due for review") that M5 fills when the
//     review queue lands. Hidden on the public static deploy.
//   - Chapter cards grouped Required (ch_1..ch_6) / Optional (ch_7,
//     ch_9..ch_13) — same partition the left rail uses on chapter
//     pages, so the user's mental model carries from index to chapter
//     and back.
//   - Footer with license + repo link.
//
// The page renders through `HomeLayout.astro` (M-UX T5 sibling of
// Base.astro) — single column, no rails, no breadcrumb. Per ADR-0002
// + T5 Notes "No left rail on the index page": putting a chapter-list
// rail next to a chapter-list grid is redundant; the cards ARE the
// chapter list at the index level. Breadcrumb is also chapter-route-
// only by design (the index has nowhere to navigate "up" to and the
// `Breadcrumb.astro` path-derivation regex returns null on non-chapter
// routes — wiring it would render an empty nav).
//
// BASE_URL convention: link composition lives inside `ChapterCard.astro`
// (each card builds `${baseUrl}/{collection}/{id}/`). This file
// itself does not produce any `/DSA/` href today. The doc-comment
// above mentions `/DSA/` only descriptively — reviewer-eyes pass per
// DA2-E / DA3-A.
//
// M-UX-REVIEW T1 update (2026-04-27):
//   - F2: Required / Optional headings drop the all-caps tracked
//     12px subtext treatment + body-weight subtitle ("6 graded
//     chapters, ~25 hours of reading"). The `<h2>` was already in
//     place from M-UX T5; T1 changes the visual register only.
//   - F3: Mounts the `<ContinueReading />` island at the top of the
//     index, above the dashboard slots + Required section. The
//     island renders empty by default (`:empty { display: none }`)
//     and populates from localStorage if the user has visited a
//     chapter on this device before. M5 supersedes this primitive
//     when the SQLite-backed `recently-read` slot lights up.
//
// Companion files:
//   - design_docs/milestones/m_ux_polish/tasks/T5_index_dashboard.md
//   - design_docs/milestones/m_ux_review/tasks/T1_home_surface.md
//   - design_docs/adr/0002_ux_layer_mdn_three_column.md
//   - src/layouts/HomeLayout.astro
//   - src/components/chrome/ChapterCard.astro
//   - src/components/chrome/DashboardSlot.astro
//   - src/components/home/ContinueReading.astro (T1 D3 — localStorage
//     resume strip)
//   - scripts/chapters.json (chapter manifest; same source of truth
//     consumed by `LeftRail.astro` so the partition stays in sync)
import HomeLayout from '../layouts/HomeLayout.astro';
import ChapterCard from '../components/chrome/ChapterCard.astro';
import DashboardSlot from '../components/chrome/DashboardSlot.astro';
import ContinueReading from '../components/home/ContinueReading.astro';
import chapters from '../../scripts/chapters.json';

// Sort by chapter number, then partition. Mirrors `LeftRail.astro`
// — same sort key (`n`, not lexicographic on `id`) so ch_10 sorts
// after ch_9; same `required` boolean partitioning.
const sorted = [...chapters].sort((a, b) => a.n - b.n);
const required = sorted.filter((c) => c.required);
const optional = sorted.filter((c) => !c.required);
---

<HomeLayout title="cs-300 — Data Structures & Algorithms">
  <header class="home-header">
    <h1>CS 300 — Data Structures &amp; Algorithms</h1>
    <p class="home-blurb">
      LaTeX-sourced lecture notes + interactive practice.
    </p>
  </header>

  <ContinueReading />

  <DashboardSlot
    heading="Recently read"
    emptyState="No recent activity yet."
  />
  <DashboardSlot
    heading="Due for review"
    emptyState="Nothing due — start reading or generate questions."
  />

  <section class="ch-group chapter-group" aria-labelledby="chapters-required-heading">
    <h2 id="chapters-required-heading" class="ch-group-heading chapter-group-heading">Required</h2>
    <p class="ch-group-sub chapter-group-blurb">6 graded chapters, ~25 hours of reading.</p>
    <div class="chapter-grid">
      {required.map((c) => (
        <ChapterCard
          id={c.id}
          n={c.n}
          title={c.title}
          subtitle={c.subtitle}
          required={c.required}
        />
      ))}
    </div>
  </section>

  <section class="ch-group chapter-group" aria-labelledby="chapters-optional-heading">
    <h2 id="chapters-optional-heading" class="ch-group-heading chapter-group-heading">Optional</h2>
    <p class="ch-group-sub chapter-group-blurb">Depth chapters; outside the graded path.</p>
    <div class="chapter-grid">
      {optional.map((c) => (
        <ChapterCard
          id={c.id}
          n={c.n}
          title={c.title}
          subtitle={c.subtitle}
          required={c.required}
        />
      ))}
    </div>
  </section>

  <footer class="home-footer">
    <p>
      <a href="https://github.com/jdelima-snhu/cs-300" rel="noopener noreferrer">Repository</a>
      <span aria-hidden="true"> · </span>
      Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" rel="noopener noreferrer">CC BY-NC-SA 4.0</a>.
    </p>
  </footer>
</HomeLayout>

<style>
  .home-header {
    margin: 0 0 var(--mux-space-8) 0;
  }

  .home-header h1 {
    margin: 0 0 var(--mux-space-2) 0;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .home-blurb {
    margin: 0;
    color: var(--mux-fg-muted);
    font-size: 0.95rem;
  }

  /* M-UX-REVIEW T1 D2 — Required / Optional reads as a section
     header, not 12px tracked subtext. The `.ch-group` class is the
     T1 spec's contract name; `.chapter-group` is preserved as a
     legacy alias so any existing consumer / cycle-1 selector still
     finds it. ~1.25rem above each group via `margin-top` so sections
     feel like sections (was ~0.5rem implicit from `chapter-group`'s
     bottom margin only). */
  .ch-group,
  .chapter-group {
    margin: var(--mux-space-6) 0 var(--mux-space-8) 0;
  }
  /* First group sits flush against the strip / dashboard slots above
     — no extra top margin needed for the first section. */
  .ch-group:first-of-type,
  .chapter-group:first-of-type {
    margin-top: var(--mux-space-4);
  }

  .ch-group-heading,
  .chapter-group-heading {
    /* T1 D2 — drop the all-caps tracked treatment; H2 reads as a
       section header at body weight + 1.5rem. */
    margin: 0 0 var(--mux-space-1) 0;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--mux-fg);
  }

  .ch-group-sub,
  .chapter-group-blurb {
    /* T1 D2 — body-weight subtitle (was 12px). The Required group's
       text "6 graded chapters, ~25 hours of reading" replaces the
       cycle-1 tautological "SNHU CS 300 syllabus." per the spec. */
    margin: 0 0 var(--mux-space-4) 0;
    font-size: 0.95rem;
    color: var(--mux-fg-muted);
  }

  .chapter-grid {
    /* Auto-fit columns at >=280px each — single column on narrow
       viewports, two on tablets, three on desktop. M-UX T7's
       responsive sweep may revisit; the auto-fit floor keeps the
       cards readable at every breakpoint without an explicit @media. */
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--mux-space-4);
  }

  .home-footer {
    margin-top: var(--mux-space-8);
    padding-top: var(--mux-space-4);
    border-top: 1px solid var(--mux-border-subtle);
    font-size: 0.85rem;
    color: var(--mux-fg-subtle);
  }

  .home-footer a {
    color: var(--mux-fg-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--mux-border-subtle);
  }

  .home-footer a:hover {
    color: var(--mux-accent-strong);
    border-bottom-color: var(--mux-accent);
  }
</style>
