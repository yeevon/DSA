---
// src/pages/index.astro
//
// M2 Task T5a — chapter-listing index. Replaces the T1 placeholder.
// Reads scripts/chapters.json directly rather than going through
// Astro content collections — T5a deliberately decouples the index
// from MDX parsing because the .mdx bodies emitted by T4 trip MDX's
// JSX expression parser on literal `{` / `<` characters in chapter
// content (set notation, math). Wiring the schema and the
// dynamic chapter routes that depend on parsed MDX bodies is T5b's
// scope; the schema work is parked at
// design_docs/milestones/m2_phase2_astro/parking/T5b-content.config.ts
// for T5b to lift back into src/content.config.ts.
import Base from '../layouts/Base.astro';
import chapters from '../../scripts/chapters.json';

const sorted = [...chapters].sort((a, b) => a.n - b.n);
const required = sorted.filter((c) => c.required);
const optional = sorted.filter((c) => !c.required);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="cs-300 — Data Structures & Algorithms">
  <h1>CS 300 — Data Structures &amp; Algorithms</h1>
  <p>
    LaTeX lecture notes, compact study notes, and coach-prompt exercises.
    Source taught in pseudocode; this rewrite ports everything to C++17 and
    augments with CLRS + MIT OCW 6.006 material.
  </p>

  <p><strong>Chapter routes pending M2 T5b.</strong> The links below resolve
  once T5b lands the dynamic <code>[id].astro</code> routes for lectures /
  notes / practice and resolves the pandoc → MDX bridge issues blocking
  chapter-body rendering.</p>

  <h2>Required (SNHU CS 300 syllabus)</h2>
  <table>
    <thead>
      <tr><th>#</th><th>Title</th><th>Lectures</th><th>Notes</th><th>Practice</th></tr>
    </thead>
    <tbody>
      {required.map((c) => (
        <tr>
          <td>{c.n}</td>
          <td>{c.subtitle}</td>
          <td><a href={`${baseUrl}/lectures/${c.id}/`}>read</a></td>
          <td><a href={`${baseUrl}/notes/${c.id}/`}>read</a></td>
          <td><a href={`${baseUrl}/practice/${c.id}/`}>read</a></td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>Optional (depth chapters; outside the graded path)</h2>
  <table>
    <thead>
      <tr><th>#</th><th>Title</th><th>Lectures</th><th>Notes</th><th>Practice</th></tr>
    </thead>
    <tbody>
      {optional.map((c) => (
        <tr>
          <td>{c.n}</td>
          <td>{c.subtitle}</td>
          <td><a href={`${baseUrl}/lectures/${c.id}/`}>read</a></td>
          <td><a href={`${baseUrl}/notes/${c.id}/`}>read</a></td>
          <td><a href={`${baseUrl}/practice/${c.id}/`}>read</a></td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
