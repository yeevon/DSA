---
// src/pages/lectures/index.astro — M-UX T9 deliverable D5.
//
// Per T9 spec D5 + AC10/AC11 (and ADR-0002 §1.6), the three collection
// directories now have real landing pages instead of 404s. Each page
// renders the same Required/Optional chapter-card grouping the index
// uses, but with the page's collection emphasised on every card via
// the new `highlight` prop on `ChapterCard.astro`.
//
// This page renders at `/DSA/lectures/` (Astro auto-routes
// `pages/<dir>/index.astro` to `/<dir>/`). It is the target of
// breadcrumb's middle segment on every lectures chapter route (T9 D4)
// and complements the existing `pages/lectures/[id].astro` chapter
// route — visiting `/DSA/lectures/` lands the user on the collection
// directory, NOT a 404.
//
// Composition mirrors `src/pages/index.astro` (T5 deliverable):
//   - HomeLayout — single-column shell, no rails, no breadcrumb (the
//     landing pages are static navigation; no current-chapter context
//     to thread up).
//   - ChapterCard × 12 grouped Required (ch_1..ch_6) / Optional
//     (ch_7, ch_9..ch_13). Same partition + sort key (`n`) the index
//     and LeftRail use.
//   - `highlight="lectures"` on every card — the `Lectures` link
//     gets the accent treatment (`is-current-collection`); Notes +
//     Practice stay as subtle text per T9 spec D5.
// No M3 surfaces. No drawer. No annotations. No mark-read button.
// These pages are static navigation — per T9 spec D5 "no annotations,
// no mark-read".
//
// Build delta: +3 prerendered pages (37 → 40 post-T9).
//
// Companion files:
//   - design_docs/milestones/m_ux_polish/tasks/T9_layout_polish.md (D5)
//   - design_docs/adr/0002_ux_layer_mdn_three_column.md
//   - src/pages/index.astro (sibling — same partition logic)
//   - src/pages/notes/index.astro / practice/index.astro (T9 — siblings)
//   - src/layouts/HomeLayout.astro
//   - src/components/chrome/ChapterCard.astro (`highlight` prop added in T9)
//   - scripts/chapters.json (chapter manifest)
import HomeLayout from '../../layouts/HomeLayout.astro';
import ChapterCard from '../../components/chrome/ChapterCard.astro';
import chapters from '../../../scripts/chapters.json';

// Sort by chapter number, then partition. Mirrors `LeftRail.astro` +
// `src/pages/index.astro` so the user's mental model carries from
// the index to the landing pages and into the chapter pane.
const sorted = [...chapters].sort((a, b) => a.n - b.n);
const required = sorted.filter((c) => c.required);
const optional = sorted.filter((c) => !c.required);
---

<HomeLayout title="Lectures — cs-300">
  <header class="home-header">
    <h1>Lectures</h1>
    <p class="home-blurb">
      Long-form chapter lectures sourced from <code>chapters/ch_N/lectures.tex</code>.
    </p>
  </header>

  <section class="chapter-group" aria-labelledby="lectures-required-heading">
    <h2 id="lectures-required-heading" class="chapter-group-heading">Required</h2>
    <p class="chapter-group-blurb">SNHU CS 300 syllabus.</p>
    <div class="chapter-grid">
      {required.map((c) => (
        <ChapterCard
          id={c.id}
          n={c.n}
          title={c.title}
          subtitle={c.subtitle}
          required={c.required}
          highlight="lectures"
        />
      ))}
    </div>
  </section>

  <section class="chapter-group" aria-labelledby="lectures-optional-heading">
    <h2 id="lectures-optional-heading" class="chapter-group-heading">Optional</h2>
    <p class="chapter-group-blurb">Depth chapters; outside the graded path.</p>
    <div class="chapter-grid">
      {optional.map((c) => (
        <ChapterCard
          id={c.id}
          n={c.n}
          title={c.title}
          subtitle={c.subtitle}
          required={c.required}
          highlight="lectures"
        />
      ))}
    </div>
  </section>
</HomeLayout>

<style>
  /* Scoped styles mirror `src/pages/index.astro`'s home-page treatment
     so the visual register is consistent across landing pages. Tokens
     come from src/styles/chrome.css (imported globally by HomeLayout). */
  .home-header {
    margin: 0 0 var(--mux-space-8) 0;
  }

  .home-header h1 {
    margin: 0 0 var(--mux-space-2) 0;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .home-blurb {
    margin: 0;
    color: var(--mux-fg-muted);
    font-size: 0.95rem;
  }

  .chapter-group {
    margin: 0 0 var(--mux-space-8) 0;
  }

  .chapter-group-heading {
    margin: 0 0 var(--mux-space-1) 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mux-fg-subtle);
  }

  .chapter-group-blurb {
    margin: 0 0 var(--mux-space-4) 0;
    font-size: 0.875rem;
    color: var(--mux-fg-subtle);
  }

  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--mux-space-4);
  }
</style>
