---
// src/pages/lectures/[id].astro
//
// M2 Task T5b — dynamic route for chapter lectures.
// Renders src/content/lectures/ch_N.mdx through Astro's MDX
// integration, resolving the embedded <Definition>, <KeyIdea>,
// <Gotcha>, <Example>, <Aside>, <CodeBlock> JSX tags through T3's
// callout component library via the `components` prop on <Content />.
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Definition from '../../components/callouts/Definition.astro';
import KeyIdea from '../../components/callouts/KeyIdea.astro';
import Gotcha from '../../components/callouts/Gotcha.astro';
import Example from '../../components/callouts/Example.astro';
import Aside from '../../components/callouts/Aside.astro';
import CodeBlock from '../../components/callouts/CodeBlock.astro';
import AnnotateButton from '../../components/annotations/AnnotateButton.astro';
import AnnotationsPane from '../../components/annotations/AnnotationsPane.astro';
import SectionNav from '../../components/read_status/SectionNav.astro';
import MarkReadButton from '../../components/read_status/MarkReadButton.astro';
import LeftRail from '../../components/chrome/LeftRail.astro';
import Breadcrumb from '../../components/chrome/Breadcrumb.astro';

export async function getStaticPaths() {
  const lectures = await getCollection('lectures');
  return lectures.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const sectionIds = entry.data.sections.map((s) => s.id);
---

<Base title={`${entry.data.title} — Lectures`}>
  <Breadcrumb slot="breadcrumb" />
  <LeftRail slot="left-rail" />
  <header>
    <h1>{entry.data.title} — Lectures</h1>
    <p><em>{entry.data.subtitle}</em></p>
  </header>
  <article>
    <Content components={{ Definition, KeyIdea, Gotcha, Example, Aside, CodeBlock }} />
  </article>
  <SectionNav chapterId={entry.data.chapter_id} sections={entry.data.sections} />
  <AnnotationsPane sectionIds={sectionIds} />
  <AnnotateButton />
  <MarkReadButton />
</Base>
