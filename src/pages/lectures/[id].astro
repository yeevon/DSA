---
// src/pages/lectures/[id].astro
//
// M2 Task T5b — dynamic route for chapter lectures.
// Renders src/content/lectures/ch_N.mdx through Astro's MDX
// integration, resolving the embedded <Definition>, <KeyIdea>,
// <Gotcha>, <Example>, <Aside>, <CodeBlock> JSX tags through T3's
// callout component library via the `components` prop on <Content />.
//
// M-UX T4 update: removes the M3 fixed-left-rail `SectionNav` import
// + use (deleted in this task). Adds the right-rail TOC trio:
//   - <RightRailTOC>          — SSR section nav (anchors + read-indicator slots)
//   - <ScrollSpy>             — JS island, current-section highlight via
//                               IntersectionObserver
//   - <RightRailReadStatus>   — JS island, fetches /api/read_status and
//                               paints `[data-read]` on indicator slots
// All three mount in `Base.astro`'s `right-rail` slot per T1's slot
// contract. Lectures route only — notes/practice MDX has no
// `sections` frontmatter (their schemas don't include it per
// `src/content.config.ts`), and per T4 spec Notes those collections
// keep the right rail empty.
//
// M-UX T6 update: re-homes the M3 surfaces into their chrome slots
// (per ADR-0002 + architecture.md §1.6, T6 spec):
//   - <AnnotationsPane>  — moves into the `right-rail` slot, AFTER
//                          <RightRailReadStatus>. The pane no longer
//                          free-floats; it flows in the rail track.
//   - <MarkReadButton>   — JSX import lands in the `default` slot
//                          ABOVE the article body. Visual position
//                          stays floating bottom-left per Step 4
//                          option (i) — the M3 `position: fixed`
//                          CSS is preserved, so re-homing the JSX
//                          import is the only change. Decision
//                          captured per spec procedure — the test
//                          revealed (i) reads cleanly inside the
//                          new chrome (button still discoverable,
//                          doesn't clash with the rail at desktop,
//                          accent colour matches the chrome's
//                          green). MarkReadButton's M3 granularity
//                          (per-section, not per-chapter — option
//                          (b) per spec Notes) is preserved by
//                          keeping the single mount; the button's
//                          IntersectionObserver auto-targets the
//                          current visible section.
//   - <AnnotateButton>   — unchanged in place (floating,
//                          selection-anchored). The new chrome's
//                          stacking context doesn't clip it
//                          because its `position: fixed` lives at
//                          the body level, not inside the
//                          `right-rail` aside's stacking context.
// All M3 event + selector contracts preserved verbatim:
//   - `cs300:read-status-changed` — dispatched by MarkReadButton on
//     toggle, listened to by RightRailReadStatus + CompletionIndicator.
//   - `cs300:toc-read-status-painted` — dispatched by
//     RightRailReadStatus, listened to by MarkReadButton.
//   - `cs300:annotation-added` — dispatched by AnnotateButton on
//     POST success, listened to by AnnotationsPane.
//   - `[data-read-indicator][data-read="true"]` — selector
//     MarkReadButton.refreshMarked() reads, painted by
//     RightRailReadStatus.
//   - `data-interactive-only` — preserved on every re-homed
//     component (gating contract from M3 T5).
// Lectures-only scope per T6 spec Step 2 (MUX-BO-ISS-05 / MEDIUM-2);
// notes / practice get the chrome but no annotations / mark-read.
//
// M-UX T7 update — adds the mobile-drawer wiring:
//   - <DrawerTrigger> mounts inside <Breadcrumb>'s `drawer-trigger`
//     named slot. Renders only the hamburger button, visibility
//     CSS-gated to <1024px.
//   - <Drawer slot="drawer"> mounts in Base.astro's body-level
//     `drawer` slot (T7 amendment to T1's slot list). Renders the
//     backdrop + JS island only. **Cycle 2 refactor (2026-04-25):
//     a single LeftRail is rendered ONCE via `slot="left-rail"`;
//     CSS in Base.astro repositions the SAME aside as a fixed
//     off-canvas drawer at <1024px. This collapses the cycle 1
//     twice-render (desktop LeftRail + drawer-internal LeftRail)
//     into one DOM tree, recovering ~700 KB of duplicated
//     CompletionIndicator JSON and resolving the duplicate-id
//     HTML5-invalid finding (M-UX-T7-ISS-02 + ISS-03).** No more
//     `<LeftRail />` inside `<Drawer>`.
//
// M-UX-REVIEW T4 update (2026-04-27): D1 + D2 reshape mobile chrome.
//   D1 — `<DrawerTrigger>` moves out of `<Breadcrumb>`'s component-
//        internal `drawer-trigger` slot and into Base.astro's new
//        chrome-level `drawer-trigger` slot. The trigger is now a
//        sibling of the breadcrumb so it survives the
//        `.breadcrumb-bar { display: none }` hide at <768px
//        (UI-review F9). The slot host moved; the JSX import is
//        unchanged.
//   D2 — `<MobileChapterTOC>` mounts inside `<header>` after
//        `<CollectionTabs>` so the mobile DOM order reads
//        eyebrow → H1 → tabs → on-this-page → article. Hidden at
//        ≥768px via its own component CSS rule; the desktop
//        `<RightRailTOC>` remains the sole TOC surface above the
//        breakpoint, and Base.astro's @media rule hides the
//        right-rail aside at <768px so the two TOC surfaces never
//        paint at the same viewport. Lectures-only mount because
//        the mobile component requires the lectures-frontmatter
//        `sections` array; notes / practice routes have no
//        `sections` field on their content schemas.
//
// M-UX-REVIEW T3 update (2026-04-27): D2 promotes the chapter topic
// to H1 and demotes the "Chapter N · Lectures" coordinates to a
// small eyebrow caption (UI-review F6, MEDIUM). The user already
// reads "Chapter 4" + "Lectures" from the URL, the breadcrumb crumbs,
// the active LeftRail row, and the new collection tabs — making the
// H1 carry the same coordinates again was redundant. The chapter
// topic ("Lists, stacks, queues, deques") is the actual answer to
// "what am I reading", so it lands as the H1.
//   - eyebrow: `<p class="ch-eyebrow">Chapter 4 · Lectures</p>`
//   - h1:      `<h1>Lists, stacks, queues, deques</h1>`
//   - tabs:    `<CollectionTabs current="lectures" chapterId="ch_4" />`
// CollectionTabs is the new home for the cross-collection link
// (D1 removed the breadcrumb's collection-switcher pills + middle
// path segment; the link contract is preserved here).
// Right-rail TOC + AnnotationsPane wrap themselves in <details>
// elements (always rendered, summary CSS-hidden at desktop) so
// the same DOM tree handles both desktop fixed-rail and mobile
// content-top collapse semantics. ScrollSpy + RightRailReadStatus
// remain unchanged — their class/attribute selectors continue to
// match the (unchanged) inner TOC + read-indicator shape.
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Definition from '../../components/callouts/Definition.astro';
import KeyIdea from '../../components/callouts/KeyIdea.astro';
import Gotcha from '../../components/callouts/Gotcha.astro';
import Example from '../../components/callouts/Example.astro';
import Aside from '../../components/callouts/Aside.astro';
import CodeBlock from '../../components/callouts/CodeBlock.astro';
import AnnotateButton from '../../components/annotations/AnnotateButton.astro';
import AnnotationsPane from '../../components/annotations/AnnotationsPane.astro';
import MarkReadButton from '../../components/read_status/MarkReadButton.astro';
import LeftRail from '../../components/chrome/LeftRail.astro';
import Breadcrumb from '../../components/chrome/Breadcrumb.astro';
import CollectionTabs from '../../components/chrome/CollectionTabs.astro';
import RightRailTOC from '../../components/chrome/RightRailTOC.astro';
import ScrollSpy from '../../components/chrome/ScrollSpy.astro';
import RightRailReadStatus from '../../components/chrome/RightRailReadStatus.astro';
import Drawer from '../../components/chrome/Drawer.astro';
import DrawerTrigger from '../../components/chrome/DrawerTrigger.astro';
import MobileChapterTOC from '../../components/chrome/MobileChapterTOC.astro';

export async function getStaticPaths() {
  const lectures = await getCollection('lectures');
  return lectures.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const sectionIds = entry.data.sections.map((s) => s.id);
---

<Base title={`${entry.data.title} — Lectures`}>
  <DrawerTrigger slot="drawer-trigger" />
  <Breadcrumb slot="breadcrumb" />
  <LeftRail slot="left-rail" />
  <RightRailTOC
    slot="right-rail"
    chapterId={entry.data.chapter_id}
    sections={entry.data.sections}
  />
  <ScrollSpy slot="right-rail" />
  <RightRailReadStatus slot="right-rail" chapterId={entry.data.chapter_id} />
  <AnnotationsPane slot="right-rail" sectionIds={sectionIds} />
  <Drawer slot="drawer" />
  <MarkReadButton />
  <header>
    {/* T3 D2 (F6): eyebrow caption replaces the redundant
        "Chapter N · Lectures" H1 the user already knows. The H1
        below names the chapter TOPIC. */}
    <p class="ch-eyebrow">{entry.data.title} · Lectures</p>
    <h1>{entry.data.subtitle}</h1>
    <CollectionTabs current="lectures" chapterId={entry.data.chapter_id} />
    {/* T4 D2 — mobile-only "On this page" details. Hidden at
        ≥768px via the component's own CSS; the desktop right-rail
        TOC takes over above the breakpoint. */}
    <MobileChapterTOC sections={entry.data.sections} />
  </header>
  <article>
    {/* M-UX-REVIEW T5 (2026-04-27) — `pre: CodeBlock` routes MDX-rendered
        fenced code blocks (Shiki output, the dominant code path on
        chapter pages) through the same envelope as explicit `<CodeBlock>`
        JSX usage so every block on the page renders the F7 polish
        (8px outer margin, top-right `C++` tag, copy button). */}
    <Content components={{ Definition, KeyIdea, Gotcha, Example, Aside, CodeBlock, pre: CodeBlock }} />
  </article>
  <AnnotateButton />
</Base>
