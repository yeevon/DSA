---
// src/pages/notes/index.astro — M-UX T9 deliverable D5.
//
// Sibling of `src/pages/lectures/index.astro` for the notes
// collection. Renders at `/DSA/notes/`. See the lectures landing-page
// header for the design rationale shared by all three landing pages.
//
// `highlight="notes"` emphasises the Notes link on each chapter card;
// Lectures + Practice stay as subtle text. Otherwise structurally
// identical to the sibling pages — same Required/Optional grouping,
// same chapter partition, same HomeLayout shell.
//
// Companion files:
//   - design_docs/milestones/m_ux_polish/tasks/T9_layout_polish.md (D5)
//   - src/pages/lectures/index.astro / practice/index.astro (siblings)
//   - src/components/chrome/ChapterCard.astro
import HomeLayout from '../../layouts/HomeLayout.astro';
import ChapterCard from '../../components/chrome/ChapterCard.astro';
import chapters from '../../../scripts/chapters.json';

const sorted = [...chapters].sort((a, b) => a.n - b.n);
const required = sorted.filter((c) => c.required);
const optional = sorted.filter((c) => !c.required);
---

<HomeLayout title="Notes — cs-300">
  <header class="home-header">
    <h1>Notes</h1>
    <p class="home-blurb">
      Compact study notes — distilled summaries of the lectures, sourced from
      <code>chapters/ch_N/notes.tex</code>.
    </p>
  </header>

  <section class="chapter-group" aria-labelledby="notes-required-heading">
    <h2 id="notes-required-heading" class="chapter-group-heading">Required</h2>
    <p class="chapter-group-blurb">SNHU CS 300 syllabus.</p>
    <div class="chapter-grid">
      {required.map((c) => (
        <ChapterCard
          id={c.id}
          n={c.n}
          title={c.title}
          subtitle={c.subtitle}
          required={c.required}
          highlight="notes"
        />
      ))}
    </div>
  </section>

  <section class="chapter-group" aria-labelledby="notes-optional-heading">
    <h2 id="notes-optional-heading" class="chapter-group-heading">Optional</h2>
    <p class="chapter-group-blurb">Depth chapters; outside the graded path.</p>
    <div class="chapter-grid">
      {optional.map((c) => (
        <ChapterCard
          id={c.id}
          n={c.n}
          title={c.title}
          subtitle={c.subtitle}
          required={c.required}
          highlight="notes"
        />
      ))}
    </div>
  </section>
</HomeLayout>

<style>
  .home-header {
    margin: 0 0 var(--mux-space-8) 0;
  }

  .home-header h1 {
    margin: 0 0 var(--mux-space-2) 0;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .home-blurb {
    margin: 0;
    color: var(--mux-fg-muted);
    font-size: 0.95rem;
  }

  .chapter-group {
    margin: 0 0 var(--mux-space-8) 0;
  }

  .chapter-group-heading {
    margin: 0 0 var(--mux-space-1) 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mux-fg-subtle);
  }

  .chapter-group-blurb {
    margin: 0 0 var(--mux-space-4) 0;
    font-size: 0.875rem;
    color: var(--mux-fg-subtle);
  }

  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--mux-space-4);
  }
</style>
