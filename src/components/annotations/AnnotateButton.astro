---
// AnnotateButton.astro — M3 T6.
// Floating button that appears next to a text selection inside
// `<article>`. Click captures (section_id, offset_start, offset_end,
// text) and POSTs to /api/annotations.
//
// section_id: walks up from selection range start to the nearest
// preceding `<a id="ch_N-...">` anchor (M2 T4 emits these before
// each header).
// offsets: relative to the article container's textContent.
//
// Mounted globally via Base.astro's slot or the chapter route. The
// button itself is `position: fixed`, hidden until a selection
// fires.
//
// Per T5 conditional rendering: tag with `data-interactive-only`
// so the static-mode CSS rule hides the button on the public deploy.
---

<button id="annotate-button" data-interactive-only type="button" aria-label="Annotate selection">Annotate</button>

<style>
  #annotate-button {
    position: fixed;
    z-index: 1000;
    padding: 4px 10px;
    font-size: .8rem;
    background: #2563eb;
    color: #fff;
    border: 0;
    border-radius: 4px;
    cursor: pointer;
    display: none;
    box-shadow: 0 2px 6px rgba(0, 0, 0, .15);
  }
</style>

<script>
  const btn = document.getElementById('annotate-button');
  if (!btn) {
    console.warn('[annotate-button] button element not found');
  }

  function findSectionId(node: Node): string | null {
    let cur: Node | null = node;
    while (cur) {
      // Walk siblings backward looking for <a id="ch_N-...">.
      let prev: Node | null = cur instanceof Element ? cur.previousSibling : null;
      while (prev) {
        if (prev instanceof Element && prev.tagName === 'A' && prev.id.startsWith('ch_')) {
          return prev.id;
        }
        prev = prev.previousSibling;
      }
      cur = cur.parentNode;
    }
    return null;
  }

  function offsetWithin(container: Element, node: Node, offset: number): number {
    let total = 0;
    const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, null);
    let n: Node | null;
    while ((n = walker.nextNode())) {
      if (n === node) return total + offset;
      total += n.textContent?.length ?? 0;
    }
    return -1;
  }

  function hideButton() {
    if (btn) btn.style.display = 'none';
  }

  document.addEventListener('mouseup', () => {
    const sel = window.getSelection();
    if (!sel || sel.rangeCount === 0 || sel.isCollapsed) {
      hideButton();
      return;
    }
    const range = sel.getRangeAt(0);
    const article = (range.startContainer as Element).closest?.('article')
      ?? (range.startContainer.parentElement?.closest('article') ?? null);
    if (!article) {
      hideButton();
      return;
    }
    const text = range.toString().trim();
    if (text.length === 0) {
      hideButton();
      return;
    }
    const sectionId = findSectionId(range.startContainer);
    if (!sectionId) {
      hideButton();
      return;
    }
    const offsetStart = offsetWithin(article, range.startContainer, range.startOffset);
    const offsetEnd = offsetWithin(article, range.endContainer, range.endOffset);
    if (offsetStart < 0 || offsetEnd < 0) {
      hideButton();
      return;
    }

    const rect = range.getBoundingClientRect();
    if (btn) {
      btn.style.display = 'block';
      btn.style.left = `${rect.left + window.scrollX}px`;
      btn.style.top = `${rect.bottom + window.scrollY + 6}px`;
      btn.dataset.sectionId = sectionId;
      btn.dataset.offsetStart = String(offsetStart);
      btn.dataset.offsetEnd = String(offsetEnd);
      btn.dataset.text = text;
    }
  });

  btn?.addEventListener('click', async () => {
    const payload = {
      section_id: btn.dataset.sectionId,
      offset_start: Number(btn.dataset.offsetStart),
      offset_end: Number(btn.dataset.offsetEnd),
      text: btn.dataset.text,
    };
    try {
      const res = await fetch('/api/annotations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) console.error('[annotate-button] POST failed:', res.status);
      window.dispatchEvent(new CustomEvent('cs300:annotation-added'));
    } catch (err) {
      console.error('[annotate-button] POST error:', err);
    }
    hideButton();
    window.getSelection()?.removeAllRanges();
  });

  document.addEventListener('mousedown', (e) => {
    if (e.target !== btn) hideButton();
  });
</script>
