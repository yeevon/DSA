---
// src/components/chrome/RightRailTOC.astro â€” M-UX T4 deliverable.
//
// Per ADR-0002 (https://.../adr/0002_ux_layer_mdn_three_column.md)
// and design_docs/architecture.md Â§1.6, the right rail hosts the
// in-chapter section TOC + (in interactive mode, T6) the annotations
// pane. This component is the SSR portion: a `<nav><ul>` of section
// anchor links derived from the chapter's MDX frontmatter `sections`
// array (populated by `scripts/build-content.mjs` per
// `src/content.config.ts` lectures schema).
//
// Contract (per T4 spec):
//   - Pure SSR. No JS required for navigation. Every entry is a real
//     anchor (`<a href="#anchor">`) the static deploy can resolve.
//   - Each entry carries `data-section-id` so the sibling read-status
//     island can target it on `cs300:read-status-changed` events,
//     and `data-anchor` so the sibling ScrollSpy island can update
//     `[data-current]` on the matching entry as the reader scrolls.
//   - Each entry includes a `<span data-read-indicator data-section-id>`
//     gated via `data-interactive-only` â€” populated by the read-status
//     island in interactive mode, hidden by the T1 global rule in
//     static mode. The TOC link itself stays visible; only the inner
//     indicator span hides (matches T2's chapter-link-vs-checkmark-slot
//     gating depth â€” DA2-D / T1 audit-check #7 on innermost-element
//     gating).
//
// Marked-state contract (resolves MUX-BO-DA-2 / DA2-A):
//   - Read indicator carries `data-read="true"` when the section is
//     marked, `data-read="false"` (or omitted) otherwise. This is the
//     deterministic selector the refactored `MarkReadButton.refreshMarked()`
//     binds to (Option (a) per T4 Step 5: re-point the selector at
//     `[data-read-indicator][data-read="true"]`). It also matches M3's
//     prior `.dot[data-read]` convention from the deleted `SectionNav`,
//     so the visual semantics carry over.
//
// SectionNav refactor (per ADR-0002 + T4 Notes):
//   - The deleted `src/components/read_status/SectionNav.astro` was a
//     fixed left-rail TOC with read-status dots. Its read-status fetch
//     logic + `cs300:read-status-changed` listener migrate into the
//     sibling `RightRailReadStatus.astro` island below. Its rendering
//     responsibility (one entry per section + a read-status indicator)
//     migrates here. No two left rails (M-UX commits to a single left
//     rail for chapter nav).
//
// Mobile collapsed-rail wrapper (M-UX T7):
//   - At <1024px, ADR-0002 + architecture.md Â§1.6 specify the TOC
//     "moves to a collapsed `<details>` summary at content top."
//     The right-rail track itself reorders above main at <1024px
//     (Base.astro grid template-areas). T7 wraps this nav inside a
//     `<details class="toc-mobile-collapse">` element (no `open`
//     attribute on the parsed DOM â€” see line 108 source) rendered
//     in EVERY viewport. The desktop-open boot script below
//     (`is:inline`) calls `details.open = true` ONLY when
//     `matchMedia('(min-width: 1024px)').matches`, so:
//       - At â‰Ą1024px the script flips `open=true` synchronously
//         after parse; the `<summary>` is CSS-hidden and content
//         renders fully. (Without the flip, the CSS-hidden summary
//         would leave a `<details>`-collapsed pane invisible at
//         desktop â€” that was the regression T7 was guarding.)
//       - At <1024px the script no-ops; the parsed-DOM default
//         (closed) holds. Users tap the summary to expand. This
//         matches ADR-0002 + T7 spec line 18 "collapsed by default."
//     Users can collapse manually at desktop or expand manually at
//     mobile via the summary toggle either way.
//   - Single-DOM-tree approach (vs spec's "twice-render" suggestion
//     in T7 step 3): one TOC instance is mounted in the right-rail
//     slot, with the mobile-collapse `<details>` wrap toggled by
//     CSS + the boot script above. Twice-rendering THIS component
//     would not directly collide with RightRailReadStatus's id
//     `#cs300-toc-read-status` (that island is a SIBLING, not
//     embedded inside RightRailTOC) â€” but it WOULD duplicate the
//     `[data-anchor]` + `[data-read-indicator]` selector targets
//     ScrollSpy + RightRailReadStatus query, fragmenting the single
//     paint surface. AnnotationsPane (the other right-rail member)
//     has the same single-tree requirement for its own
//     `#annotations-pane` + `#annotations-list` ids. Wrapping in
//     one `<details>` and gating with @media + the boot script
//     keeps every selector unique per page, mirroring T7 cycle 2's
//     LeftRail single-tree resolution.
//
// Companion files:
//   - design_docs/milestones/m_ux_polish/tasks/T4_right_rail_toc.md
//   - design_docs/adr/0002_ux_layer_mdn_three_column.md
//   - src/layouts/Base.astro (T1 â€” slot contract)
//   - src/components/chrome/ScrollSpy.astro (sibling island; current-section)
//   - src/components/chrome/RightRailReadStatus.astro (sibling island;
//     read-status indicator population + live refresh)
//   - src/components/read_status/MarkReadButton.astro (M3 â€” refactored
//     in this task to read state via the new TOC's indicator selector)
interface Section {
  id: string;
  anchor: string;
  title: string;
  /**
   * Visual hierarchy level emitted by `scripts/build-content.mjs`
   * per M-UX-REVIEW T2 D1 (UI-review F4):
   *   level 1 â€” top-level numbered section (`^\d+\.\d+\s` titles like
   *             "4.1 The List ADT"). Renders bold + flush-left in the
   *             rail (`data-level="1"`).
   *   level 2 â€” H2 subsection underneath ("The contract: operations").
   *             Renders indented + muted (`data-level="2"`).
   * Reverses the M-UX b29d409 frontmatter-side filter rule that
   * dropped every non-`^\d+\.\d+\s` entry; both levels now render.
   */
  level: 1 | 2;
  ord: number;
}

interface Props {
  /**
   * The chapter id this TOC describes (e.g. "ch_4"). Used by the
   * read-status island for the GET /api/read_status?chapter_id= fetch
   * (matches M3's deleted `SectionNav` contract verbatim â€” same
   * endpoint, same query param, same response shape).
   */
  chapterId: string;
  /**
   * The chapter's section list, read from the lectures collection's
   * MDX frontmatter (the `sections` array `scripts/build-content.mjs`
   * populates per `src/content.config.ts` lectures schema). Sorted by
   * `ord` ascending so the TOC mirrors the source ordering.
   */
  sections: Section[];
}

const { chapterId, sections } = Astro.props;

// Defensive sort by `ord` â€” the build script emits in-order today,
// but pinning it here means a future frontmatter shape change (or an
// unsorted handwritten override) cannot silently scramble the TOC.
//
// M-UX-REVIEW T2 D2 (2026-04-27): the M-UX b29d409 `^\d+\.\d+\s`
// filter that dropped subsection titles is removed. The rail now
// renders every entry the lectures frontmatter declares (top-level
// numbered + H2 subsections; H3+ already dropped at the build-script
// boundary per T2 D1). Visual hierarchy is delivered via the
// `data-level` attribute set per <li> below â€” the chrome.css rules
// at `src/styles/chrome.css` paint level=1 bold + flush-left and
// level=2 indented + muted (UI-review F4). ScrollSpy's `setCurrent()`
// guard still ignores non-TOC anchors; with the rail now covering
// both H1 and H2 the guard rarely fires (only sub-subsection IDs in
// articles that use `\subsubsection` would trip it).
//
// M-UX-REVIEW followup (2026-04-27) â€” filter to top-level (level=1)
// only. The cs-300 chapter corpus is split: ch_1â€“ch_4 lectures use
// numbered `\subsection{...}` (anchored, extracted as level=2 in
// frontmatter), while ch_5+ use `\subsection*{...}` (unnumbered, no
// anchor, NOT extracted by `scripts/build-content.mjs`). Result
// pre-filter: ch_4's right-rail showed 68 entries while ch_5's
// showed 9. User flagged the per-chapter inconsistency as worse than
// uniform-shallow rendering ("don't care which but not both"). Until
// the chapter corpus is normalized via a content-audit pass
// (rewrite `\subsection*{}` â†’ `\subsection{}` across ch_5â€“ch_13),
// the consumer filter keeps the rail uniform across all chapters.
// Reverses T2's D1 H2-rendering on the rendering side; build-time
// frontmatter still carries level=2 entries for any future surface
// that wants them (e.g. M5 review-queue scheduling that may need
// per-section data).
const ordered = [...sections]
  .filter((s) => s.level === 1)
  .sort((a, b) => a.ord - b.ord);
---

<details class="toc-mobile-collapse">
  <summary class="toc-mobile-summary">
    <span class="toc-mobile-summary-label">On this page</span>
  </summary>
  <nav
    class="right-rail-toc"
    aria-label="In-chapter sections"
    data-chapter-id={chapterId}
  >
    <h3 class="right-rail-toc-heading">On this page</h3>
    <ul>
      {ordered.map((s) => (
        <li data-level={String(s.level)}>
          <a
            href={`#${s.anchor}`}
            class="toc-link"
            data-section-id={s.id}
            data-anchor={s.anchor}
            data-level={String(s.level)}
          >
            <span
              class="read-indicator"
              data-read-indicator
              data-section-id={s.id}
              data-interactive-only
              aria-hidden="true"
            ></span>
            <span class="toc-label">{s.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</details>

<style>
  /* Scoped styles; tokens come from src/styles/chrome.css (imported
     globally by Base.astro). */
  .right-rail-toc {
    font-size: 0.85rem;
  }

  /* Mobile-collapse wrapper (T7). At â‰Ą1024px, the wrapper is
     layout-transparent and the `<summary>` is visually hidden; the
     `<details open>` browser default keeps `<nav>` children
     rendered. At <1024px, the summary is visible and tappable so
     users can collapse the TOC inline at content top. */
  .toc-mobile-collapse {
    /* `display: contents` would remove the `<details>` from the
       layout entirely, but `<details>` browser styling (the
       expand/collapse arrow) only renders correctly when the
       element is in normal flow. Use `block` and let the children
       inherit the rail-padding from Base.astro. */
    display: block;
  }

  .toc-mobile-summary {
    /* Hidden at desktop â€” the inner `<h3>` plays the heading role
       there. Visible + styled like a small caps heading at <1024px
       with a click affordance. */
    display: none;
    cursor: pointer;
    padding: var(--mux-space-2) var(--mux-space-3);
    margin: 0 0 var(--mux-space-2) 0;
    border-radius: 4px;
    background: var(--mux-surface-alt);
    list-style: none;
    user-select: none;
  }

  .toc-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .toc-mobile-summary-label {
    /* Match `.right-rail-toc h3` register so the mobile summary
       reads the same as the desktop heading. */
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mux-fg-subtle);
  }

  .toc-mobile-summary::before {
    /* Disclosure triangle. Rotates when `<details>` is open. */
    content: 'â–¸';
    display: inline-block;
    margin-right: var(--mux-space-2);
    color: var(--mux-fg-subtle);
    font-size: 0.7rem;
    transition: transform 120ms ease;
  }

  .toc-mobile-collapse[open] > .toc-mobile-summary::before {
    transform: rotate(90deg);
  }

  @media (max-width: 1023.98px) {
    .toc-mobile-summary {
      display: flex;
      align-items: center;
    }
    /* Hide the desktop `<h3>` at <1024px â€” the summary plays its
       role there. */
    .right-rail-toc-heading {
      display: none;
    }
  }

  .right-rail-toc h3 {
    /* Section heading idiom mirrors LeftRail's `.group h3` â€” small
       caps, de-emphasized. */
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mux-fg-subtle);
    margin: 0 0 var(--mux-space-2) 0;
    padding: 0 var(--mux-space-2);
  }

  .right-rail-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .right-rail-toc li {
    margin: 0;
  }

  .toc-link {
    display: flex;
    align-items: center;
    gap: var(--mux-space-2);
    padding: var(--mux-space-1) var(--mux-space-3);
    border-radius: 4px;
    color: var(--mux-fg-muted);
    text-decoration: none;
    line-height: 1.35;
  }

  .toc-link:hover {
    background: var(--mux-surface-alt);
    color: var(--mux-fg);
  }

  /* Current-section highlight applied by the ScrollSpy island via
     [data-current="true"]. Distinct from hover via the accent
     left-bar idiom â€” same shape as LeftRail's `.is-current` rule
     so chrome surfaces share visual language. */
  .toc-link[data-current="true"] {
    background: var(--mux-accent-bg);
    color: var(--mux-fg);
    font-weight: 600;
    box-shadow: inset 3px 0 0 var(--mux-accent);
  }

  .toc-label {
    flex: 1;
    overflow-wrap: anywhere;
  }

  .read-indicator {
    /* Mirrors M3's deleted `SectionNav .dot` shape so the visual
       carry-over is exact: small dot, neutral by default, accent
       when `data-read="true"`. Reserve the inline space so the
       label doesn't reflow when the indicator paints. */
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mux-border);
    flex-shrink: 0;
    /* `display: inline-block` keeps width/height on the inline span
       even when the [data-interactive-only] rule is removed (the
       outer flex still needs a non-zero size). */
    display: inline-block;
  }

  .read-indicator[data-read="true"] {
    background: var(--mux-accent);
  }
</style>

<script is:inline>
  /**
   * Open the TOC `<details>` wrapper at desktop widths so the
   * collapsed-mobile-`<details>` initial state doesn't hide the
   * TOC at â‰Ą1024px (where the `<summary>` is CSS-hidden â€” without
   * `open`, content would be hidden too). Runs synchronously after
   * parse via `is:inline` so there's no FOUC at desktop.
   *
   * The matching media query keeps this in lockstep with
   * `Base.astro`'s `(min-width: 1024px)` desktop breakpoint and the
   * `.toc-mobile-summary` `(max-width: 1023.98px)` visibility rule
   * â€” single source of truth at 1024px.
   *
   * On viewport resize across the breakpoint (e.g. user rotates a
   * tablet), the listener re-applies â€” opens at desktop, leaves
   * collapsed if the user manually collapsed at mobile (inferred
   * from the user-toggled state being preserved across resize
   * frames).
   */
  (function () {
    var details = document.querySelectorAll('.toc-mobile-collapse');
    if (!details.length) return;
    var mql = window.matchMedia('(min-width: 1024px)');
    function apply(e) {
      details.forEach(function (d) {
        if (e.matches) {
          d.open = true;
        }
      });
    }
    apply(mql);
    if (mql.addEventListener) {
      mql.addEventListener('change', apply);
    } else if (mql.addListener) {
      // Safari fallback for older webkits.
      mql.addListener(apply);
    }
  })();
</script>
