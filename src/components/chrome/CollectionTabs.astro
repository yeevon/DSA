---
// src/components/chrome/CollectionTabs.astro — M-UX-REVIEW T3 D2.
//
// Per design_docs/milestones/m_ux_review/tasks/T3_chapter_chrome.md
// (F5 + F6, paired) and architecture.md §1 page-chrome (T3 amendment):
// the collection switcher (Lectures / Notes / Practice) hoists out of
// the breadcrumb bar and lands as a segmented-control-style tab strip
// directly under the chapter page H1. Three roles in the chrome read
// as three rows now — breadcrumb (crumbs + chapter prev/next),
// eyebrow + H1, and these tabs.
//
// Contract:
//   - Pure SSR. Each tab is a real `<a>` with a chapter-scoped href so
//     the static deploy navigates without JS.
//   - The current collection's tab carries `aria-current="page"` and
//     a filled visual treatment (accent background + ring); the other
//     two render as outline-only and pick up the accent on hover.
//   - Props: `current` ('lectures' | 'notes' | 'practice') + `chapterId`
//     ('ch_4' etc). The chapter route templates pass the literals
//     they already know — no URL parsing here so the component stays
//     trivially testable + the chapter-route call site reads as
//     a single declarative line.
//   - Visual rhythm: same accent tokens (`--mux-accent`,
//     `--mux-accent-bg`) the LeftRail current-chapter highlight uses,
//     so the user reads "current" the same way across both surfaces.
//
// Animation: instant. Per the M-UX motion rule — no animated tab
// transitions (T3 spec "Out of scope").
//
// Companion files:
//   - src/components/chrome/Breadcrumb.astro — sibling chrome that
//     used to host the collection-switcher pills (T3 D1 removed them).
//   - src/pages/{lectures,notes,practice}/[id].astro — chapter routes
//     that mount this component below the H1 (T3 D2 part 2).
//   - src/styles/chrome.css — shared tokens consumed via cascade.
//   - design_docs/milestones/m_ux_review/tasks/T3_chapter_chrome.md
//   - design_docs/architecture.md §1 page-chrome (T3 update)

const COLLECTIONS = ['lectures', 'notes', 'practice'] as const;
type Collection = (typeof COLLECTIONS)[number];

interface Props {
  current: Collection;
  chapterId: string;
}

const { current, chapterId } = Astro.props;

const COLLECTION_LABEL: Record<Collection, string> = {
  lectures: 'Lectures',
  notes: 'Notes',
  practice: 'Practice',
};

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

function tabHref(collection: Collection): string {
  return `${baseUrl}/${collection}/${chapterId}/`;
}
---

<nav class="collection-tabs" aria-label="Collection switcher">
  <ul>
    {COLLECTIONS.map((c) => (
      <li>
        <a
          href={tabHref(c)}
          class:list={['collection-tab', c === current && 'is-current']}
          aria-current={c === current ? 'page' : undefined}
        >
          {COLLECTION_LABEL[c]}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  /* Scoped — tokens come from src/styles/chrome.css (imported globally
     by Base.astro). Visual rhythm matches the LeftRail current-chapter
     highlight (accent background + ring) so "current" reads identically
     across chrome surfaces. */
  .collection-tabs {
    margin: var(--mux-space-3) 0 var(--mux-space-4);
  }

  .collection-tabs ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--mux-space-2);
    flex-wrap: wrap;
  }

  .collection-tabs li {
    margin: 0;
  }

  .collection-tab {
    display: inline-block;
    padding: var(--mux-space-2) var(--mux-space-4);
    border: 1px solid var(--mux-border);
    border-radius: 6px;
    color: var(--mux-fg-muted);
    background: var(--mux-surface);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .collection-tab:hover {
    color: var(--mux-fg);
    border-color: var(--mux-accent);
  }

  .collection-tab.is-current {
    /* Filled accent for the current collection. Matches LeftRail's
       current-chapter idiom (accent background + accent ring) so
       "current" reads identically across both chrome surfaces. */
    background: var(--mux-accent-bg);
    color: var(--mux-fg);
    border-color: var(--mux-accent);
    font-weight: 600;
    box-shadow: inset 0 0 0 1px var(--mux-accent);
  }
</style>
