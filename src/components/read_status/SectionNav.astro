---
// SectionNav.astro — M3 T7.
// Fixed left-side TOC for the current chapter. Renders one link
// per section with a colored dot reflecting read/unread state.
// Loads marked sections once on mount via GET
// /api/read_status?chapter_id=…; click toggles read/unread.
//
// Data-interactive-only per T5 contract — hidden on the static
// public deploy.
interface Section {
  id: string;
  anchor: string;
  title: string;
  ord: number;
}
interface Props {
  chapterId: string;
  sections: Section[];
}

const { chapterId, sections } = Astro.props;
---

<aside id="section-nav" data-interactive-only data-chapter-id={chapterId}>
  <header><strong>Sections</strong></header>
  <ul>
    {sections.map((s) => (
      <li>
        <span class="dot" data-section-id={s.id} aria-label="Read status indicator"></span>
        <a href={`#${s.anchor}`} class="title">{s.title}</a>
      </li>
    ))}
  </ul>
</aside>

<style>
  #section-nav {
    position: fixed;
    top: 64px;
    left: 0;
    width: 240px;
    max-height: 80vh;
    overflow-y: auto;
    background: #fff;
    border-right: 1px solid #d1d5db;
    box-shadow: 2px 0 8px rgba(0, 0, 0, .05);
    padding: 12px;
    font-size: .82rem;
    z-index: 900;
  }
  #section-nav header { margin-bottom: 8px; color: #4b5563; }
  #section-nav ul { list-style: none; padding: 0; margin: 0; }
  #section-nav li { padding: 4px 0; display: flex; gap: 6px; align-items: center; }
  #section-nav .dot { width: 8px; height: 8px; border-radius: 50%; background: #d1d5db; flex-shrink: 0; }
  #section-nav .dot[data-read="true"] { background: #16a34a; }
  #section-nav .title { color: #1f2937; text-decoration: none; flex: 1; }
  #section-nav .title:hover { text-decoration: underline; }
</style>

<script>
  const nav = document.getElementById('section-nav');
  if (!nav) {
    console.warn('[section-nav] element not found');
  } else {
    const chapterId = nav.dataset.chapterId ?? '';

    async function loadMarked(): Promise<Set<string>> {
      try {
        const res = await fetch(`/api/read_status?chapter_id=${encodeURIComponent(chapterId)}`);
        if (!res.ok) return new Set();
        const body = (await res.json()) as { section_ids: string[] };
        return new Set(body.section_ids);
      } catch {
        return new Set();
      }
    }

    function applyMarks(marked: Set<string>) {
      nav?.querySelectorAll<HTMLElement>('.dot').forEach((dot) => {
        const id = dot.dataset.sectionId ?? '';
        dot.dataset.read = marked.has(id) ? 'true' : 'false';
      });
    }

    loadMarked().then(applyMarks);

    // Listen for mark/unmark events from MarkReadButton.
    window.addEventListener('cs300:read-status-changed', () => {
      loadMarked().then(applyMarks);
    });
  }
</script>
