---
// Gotcha.astro — Renders warnbox callouts from chapter LaTeX.
// Source: \begin{warnbox}[Title]…\end{warnbox}
// Pandoc filter emits <Gotcha title="…">.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside class="callout callout-gotcha">
  {title && <header class="callout-title">{title}</header>}
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout-gotcha {
    border-left: 4px solid #dc2626;
    background: #fef2f2;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 0 4px 4px 0;
  }
  .callout-gotcha .callout-title {
    font-weight: 600;
    color: #b91c1c;
    margin-bottom: 0.4rem;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
