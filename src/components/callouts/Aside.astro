---
// Aside.astro — Renders notebox callouts from chapter LaTeX.
// Source: \begin{notebox}[Title]…\end{notebox}
// Pandoc filter emits <Aside title="…">.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside class="callout callout-aside">
  {title && <header class="callout-title">{title}</header>}
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout-aside {
    border-left: 4px solid #6b7280;
    background: #f9fafb;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 0 4px 4px 0;
  }
  .callout-aside .callout-title {
    font-weight: 600;
    color: #4b5563;
    margin-bottom: 0.4rem;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
