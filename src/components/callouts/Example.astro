---
// Example.astro — Renders examplebox callouts from chapter LaTeX.
// Source: \begin{examplebox}[Title]…\end{examplebox}
// Pandoc filter emits <Example title="…">.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside class="callout callout-example">
  {title && <header class="callout-title">{title}</header>}
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout-example {
    border-left: 4px solid #7c3aed;
    background: #faf5ff;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 0 4px 4px 0;
  }
  .callout-example .callout-title {
    font-weight: 600;
    color: #6d28d9;
    margin-bottom: 0.4rem;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
