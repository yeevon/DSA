---
// KeyIdea.astro — Renders ideabox callouts from chapter LaTeX.
// Source: \begin{ideabox}[Title]…\end{ideabox}
// Pandoc filter emits <KeyIdea title="…">.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside class="callout callout-keyidea">
  {title && <header class="callout-title">{title}</header>}
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout-keyidea {
    border-left: 4px solid #16a34a;
    background: #f0fdf4;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 0 4px 4px 0;
  }
  .callout-keyidea .callout-title {
    font-weight: 600;
    color: #15803d;
    margin-bottom: 0.4rem;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
