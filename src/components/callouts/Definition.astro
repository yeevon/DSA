---
// Definition.astro — Renders defnbox callouts from chapter LaTeX.
// Source: \begin{defnbox}[Title]…\end{defnbox}
// Pandoc filter at scripts/pandoc-filter.lua emits <Definition title="…">.
//
// Visual identity matches notes-style.tex's defnbox tcolorbox in the
// generated PDFs: a left accent rule + title bar + body text. Pixel
// parity with the PDFs is not the goal; the information hierarchy
// (title bar | body | accent colour) is what carries.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside class="callout callout-definition">
  {title && <header class="callout-title">{title}</header>}
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout-definition {
    border-left: 4px solid #2563eb;
    background: #eff6ff;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 0 4px 4px 0;
  }
  .callout-definition .callout-title {
    font-weight: 600;
    color: #1d4ed8;
    margin-bottom: 0.4rem;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
