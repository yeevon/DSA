---
// Base.astro — minimal HTML shell used by every page.
// Styling lands in M2 T3 (callout components) and follow-on UI work;
// this layout is intentionally bare so the scaffold has a single
// place to grow from without committing to a design.
//
// M3 T5 — bootstrap mode probe. The inline script imports
// detectMode() at runtime, sets `<body data-mode="static|interactive">`,
// and the scoped CSS rule below hides any element flagged
// `data-interactive-only` when mode is static. T6 + T7 components
// carry that attribute so they're invisible on the public deploy
// (where /api/health 404s) and visible in local interactive mode
// (where the M4 adapter + state service are both reachable).
interface Props {
  title?: string;
}

const { title = 'cs-300' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
    <style is:global>
      body[data-mode="static"] [data-interactive-only] {
        display: none !important;
      }
    </style>
  </head>
  <body data-mode="static">
    <header><strong>cs-300</strong></header>
    <main>
      <slot />
    </main>
    <footer></footer>
    <div data-interactive-only style="position:fixed;bottom:8px;right:8px;font-size:.75rem;background:#16a34a;color:#fff;padding:2px 8px;border-radius:4px;">
      interactive mode active
    </div>
    <script>
      import { detectMode } from '../lib/mode';
      detectMode().then((mode) => {
        document.body.dataset.mode = mode;
      });
    </script>
  </body>
</html>
